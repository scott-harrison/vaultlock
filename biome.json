{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "backend/target/**",
      "desktop/src-tauri/target/**",
      "desktop/dist/**",
      "desktop/src-tauri/gen/**",
      "extension/build/**",
      "extension/.plasmo/**",
      "extension/src/contents/lib/autofillTokensCss.ts"
    ]
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useImportType": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  }
}
