meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "user@example.com",
    "password": "password123"
  }
}

assert {
  res.status: eq 200
  res.body: contains "token"
}

script:post-response {
  const body = res.getBody();
  if (body.token) {
    console.log('Login successful, token received');
  }
}