# Copy to `.env` in the repo root for local backend development.
# Never commit `.env` — it is gitignored.

# PostgreSQL (matches docker-compose postgres service)
DATABASE_URL=postgres://vaultlock:vaultlock@localhost:5432/vaultlock

# Required — use a long random string in production (≥ 32 characters)
JWT_SECRET=dev-jwt-secret-change-before-production-use-64-chars-min!!

# Optional — required only for the register → email verification flow.
# Registration still creates the user if unset; verification email will fail.
# For local dev, read the token from the database or use Bruno/API tests.
RESEND_API_KEY=

# Public URL of this backend — used for clickable verification links in email.
# Default: http://localhost:8080
PUBLIC_BASE_URL=

# Optional — override the full verification link template, e.g.
# https://app.example/verify?token={token}
VERIFY_EMAIL_URL=

# Backend log level
RUST_LOG=vaultlock_backend=debug,tower_http=debug

# Auth rate limiting — memory (default), postgres, or redis
# Use postgres or redis when running multiple backend replicas
RATE_LIMIT_STORE=memory

# Required when RATE_LIMIT_STORE=redis
# REDIS_URL=redis://localhost:6379

# Optional — defaults: 5 requests per 60 seconds per client IP
# AUTH_RATE_LIMIT_MAX=5
# AUTH_RATE_LIMIT_WINDOW_SECS=60
