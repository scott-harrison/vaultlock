# Copy to `.env` in the repo root for local backend development.
# Never commit `.env` — it is gitignored.

# PostgreSQL (matches docker-compose postgres service)
DATABASE_URL=postgres://vaultlock:vaultlock@localhost:5432/vaultlock

# Required — use a long random string in production (≥ 32 characters)
JWT_SECRET=dev-jwt-secret-change-before-production-use-64-chars-min!!

# Optional — required only for the register → email verification flow.
# Registration still creates the user if unset; verification email will fail.
# For local dev, read the token from the database or use Bruno/API tests.
RESEND_API_KEY=

# Backend log level
RUST_LOG=vaultlock_backend=debug,tower_http=debug
